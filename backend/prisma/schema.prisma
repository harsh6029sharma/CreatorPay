generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DealStatus {
  PITCHED
  NEGOTIATING
  CONFIRMED
  PAID
  REJECTED
}

enum PaymentStatus {
  PENDING
  REMINDED
  PAID
  OVERDUE
}

enum NotificationType {
  STATUS_CHANGE
  PAYMENT_REMINDER
  PAYMENT_OVERDUE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  refreshTokens RefreshToken[]
  brandDeals    BrandDeal[]
  notifications Notification[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandDeal {
  id           String     @id @default(cuid())
  brandName    String
  dealValue    Decimal    @db.Decimal(12, 2)
  currency     String     @default("INR")
  status       DealStatus @default(PITCHED)
  deadline     DateTime
  notes        String?
  contactEmail String?
  contactName  String?
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payment       Payment?
  notifications Notification[]
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  dueDate       DateTime
  status        PaymentStatus @default(PENDING)
  reminderJobId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  brandDealId String    @unique
  brandDeal   BrandDeal @relation(fields: [brandDealId], references: [id], onDelete: Cascade)

  notifications Notification[]
}

model Notification {
  id        String           @id @default(cuid())
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brandDealId String?
  brandDeal   BrandDeal? @relation(fields: [brandDealId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])
}
